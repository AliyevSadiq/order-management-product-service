{
    "name": "app/product-service",
    "description": "Product microservice for Order Management System",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "alvarorosado/event-driven-kafka-messenger-transport": "^0.1.9",
        "doctrine/doctrine-bundle": "^2.11",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.0",
        "friendsofsymfony/elastica-bundle": "^6.4",
        "nelmio/api-doc-bundle": "^5.9",
        "nelmio/cors-bundle": "^2.4",
        "promphp/prometheus_client_php": "^2.14",
        "sentry/sentry-symfony": "^5.0",
        "symfony/cache": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/monolog-bundle": "^3.10",
        "symfony/property-access": "^7.0",
        "symfony/property-info": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/uid": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/var-exporter": "^8.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/test-pack": "^1.1",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    }
}
